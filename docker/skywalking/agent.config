# SkyWalking Agent 配置文件
# 服务名称，用于在 SkyWalking UI 中标识服务
agent.service_name=${SW_AGENT_NAME:core-ledger-account}

# SkyWalking OAP 服务地址
collector.backend_service=${SW_AGENT_COLLECTOR_BACKEND_SERVICES:127.0.0.1:11800}

# 日志级别
logging.level=${SW_LOGGING_LEVEL:INFO}

# 日志文件名称
logging.file_name=${SW_LOGGING_FILE_NAME:skywalking-api.log}

# 日志输出目录
logging.dir=${SW_LOGGING_DIR:/logs/skywalking}

# 日志输出格式
logging.pattern=%level %timestamp [%thread] %logger : %msg %throwable%n

# 采样率，1.0 表示 100% 采样
agent.sample_n_per_3_secs=${SW_AGENT_SAMPLE:-1}

# 开启 MySQL 插件
plugin.mysql.enable=${SW_PLUGIN_MYSQL_ENABLE:true}

# 开启 Dubbo 插件
plugin.dubbo.enable=${SW_PLUGIN_DUBBO_ENABLE:true}

# 开启 Spring MVC 插件
plugin.springmvc.enable=${SW_PLUGIN_SPRINGMVC_ENABLE:true}

# 开启 Spring Transaction 插件
plugin.spring.transaction.enable=${SW_PLUGIN_SPRING_TX_ENABLE:true}

# 开启 Redis 插件
plugin.lettuce.enable=${SW_PLUGIN_LETTUCE_ENABLE:true}
plugin.jedis.enable=${SW_PLUGIN_JEDIS_ENABLE:true}

# 开启 RocketMQ 插件
plugin.rocketmq.enable=${SW_PLUGIN_ROCKETMQ_ENABLE:true}

# 开启 Seata 插件
plugin.seata.enable=${SW_PLUGIN_SEATA_ENABLE:true}

# 开启 MyBatis 插件
plugin.mybatis.enable=${SW_PLUGIN_MYBATIS_ENABLE:true}

# 开启 ShardingSphere 插件
plugin.shardingsphere.enable=${SW_PLUGIN_SHARDINGSPHERE_ENABLE:true}

# 开启 Feign 插件
plugin.feign.enable=${SW_PLUGIN_FEIGN_ENABLE:true}

# 开启 RestTemplate 插件
plugin.spring.annotation.enable=${SW_PLUGIN_SPRING_ANNOTATION_ENABLE:true}

# 排除的路径，不进行追踪
plugin.springmvc.exclude_paths=${SW_PLUGIN_SPRINGMVC_EXCLUDE_PATHS:/actuator/**,/swagger/**,/v2/api-docs,/doc.html}

# 最大追踪跨度数量
agent.max_capture_depth=300

# 开启线程池跟踪
agent.threading.class_prefix=com.bank.core

# 开启日志收集到 SkyWalking
plugin.toolkit.log.grpc.reporter.server_host=${SW_GRPC_LOG_SERVER_HOST:127.0.0.1}
plugin.toolkit.log.grpc.reporter.server_port=${SW_GRPC_LOG_SERVER_PORT:11800}
plugin.toolkit.log.grpc.reporter.max_message_size=${SW_GRPC_LOG_MAX_MESSAGE_SIZE:10485760}
plugin.toolkit.log.grpc.reporter.upstream_timeout=${SW_GRPC_LOG_GRPC_UPSTREAM_TIMEOUT:30}

# 慢接口阈值（毫秒）
agent.trace.ignore_suffix=.jpg,.jpeg,.js,.css,.png,.bmp,.gif,.ico,.mp3,.mp4,.html,.svg
agent.trace.span_limit_per_segment=300

# 自定义增强类
# 可以在这里添加自定义的类需要被 SkyWalking 追踪
plugin.customize.enhance.enable=false

# 开启 gRPC 日志上报
plugin.toolkit.log.transmit_formatted=true

# 异常忽略列表，不记录到 Error 中
status_check.ignored_exceptions=

# 开启自定义 tag 配置
correlation.element.max_number=3
correlation.value.max_length=128

# Seata 相关配置
plugin.seata.trace_annotation=true
plugin.seata.transfer.xid=true
